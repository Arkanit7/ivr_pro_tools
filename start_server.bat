@echo off
powershell -ExecutionPolicy Bypass -Command "$l = New-Object System.Net.HttpListener; $l.Prefixes.Add('http://localhost:4173/'); $l.Start(); Write-Host 'Server started at http://localhost:4173' -ForegroundColor Green; while($l.IsListening) { $c = $l.GetContext(); $p = Join-Path $pwd $c.Request.Url.LocalPath.TrimStart('/'); if (!(Test-Path $p) -or (Test-Path $p -PathType Container)) { $p = Join-Path $p 'index.html' }; $ext = [System.IO.Path]::GetExtension($p); $mime = switch($ext) { '.js' {'application/javascript'} '.css' {'text/css'} '.html' {'text/html'} '.svg' {'image/svg+xml'} '.png' {'image/png'} default {'application/octet-stream'} }; $b = [System.IO.File]::ReadAllBytes($p); $c.Response.ContentType = $mime; $c.Response.ContentLength64 = $b.Length; $c.Response.OutputStream.Write($b, 0, $b.Length); $c.Response.Close() }"
pause